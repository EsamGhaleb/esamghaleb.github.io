{% comment %}
  Unified languages entry renderer for both formats
  - RenderCV uses: name, summary
  - JSONResume uses: language, fluency
{% endcomment %}

<div class="cv-languages-list">
  {% for entry in entries %}
    {% capture lang_name %}
      {% if entry.name %}{{ entry.name }}{% elsif entry.language %}{{ entry.language }}{% endif %}
    {% endcapture %}
    {% assign lang_name = lang_name | strip %}

    {% capture fluency %}
      {% if entry.summary %}{{ entry.summary }}{% elsif entry.fluency %}{{ entry.fluency }}{% endif %}
    {% endcapture %}
    {% assign fluency = fluency | strip %}

    {% assign fluency_down = fluency | downcase %}
    {% assign lang_class = 'is-mid' %}

    {% if fluency_down contains 'native' or fluency_down contains 'bilingual' %}
      {% assign lang_class = 'is-top' %}
    {% elsif fluency_down contains 'fluent' or fluency_down contains 'c1' or fluency_down contains 'c2' %}
      {% assign lang_class = 'is-high' %}
    {% elsif fluency_down contains 'b2' or fluency_down contains 'upper intermediate' %}
      {% assign lang_class = 'is-good' %}
    {% endif %}

    <div class="cv-language-pill {{ lang_class }}">
      <div class="cv-language-pill-main">
        {% if entry.icon %}
          <i class="{{ entry.icon }} cv-language-icon"></i>
        {% endif %}
        <span class="cv-language-name">{{ lang_name }}</span>
      </div>

      {% if fluency != blank %}
        <span class="cv-language-level">{{ fluency }}</span>
      {% endif %}
    </div>
  {% endfor %}
</div>